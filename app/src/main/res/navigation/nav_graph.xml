<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.tasneem.mealplanner.presentation.home.view.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_homeFragment_to_mealDetailsFragment"
            app:destination="@id/mealDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/mealDetailsFragment"
        android:name="com.tasneem.mealplanner.presentation.mealdetails.view.MealDetailsFragment"
        android:label="Meal Details">
        <argument
            android:name="mealId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.tasneem.mealplanner.presentation.search.view.SearchFragment"
        android:label="Search" />

    <fragment
        android:id="@+id/plannerFragment"
        android:name="com.tasneem.mealplanner.presentation.planner.view.PlannerFragment"
        android:label="Planner" />

    <fragment
        android:id="@+id/favoritesFragment"
        android:name="com.tasneem.mealplanner.presentation.favorites.view.FavoritesFragment"
        android:label="Favorites" />

</navigation>