<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.MealPlanner" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <!-- Surface colors -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Typography -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.MealPlanner.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.MealPlanner.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.MealPlanner.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.MealPlanner.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.MealPlanner.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.MealPlanner.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.MealPlanner.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.MealPlanner.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.MealPlanner.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.MealPlanner.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.MealPlanner.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.MealPlanner.LabelSmall</item>

        <!-- Shapes -->
        <item name="shapeAppearanceSmallComponent">
            @style/ShapeAppearance.MealPlanner.SmallComponent
        </item>
        <item name="shapeAppearanceMediumComponent">
            @style/ShapeAppearance.MealPlanner.MediumComponent
        </item>
        <item name="shapeAppearanceLargeComponent">
            @style/ShapeAppearance.MealPlanner.LargeComponent
        </item>
    </style>

    <style name="Theme.MealPlanner" parent="Base.Theme.MealPlanner" />

    <style name="Theme.MyApp.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/white</item>

        <item name="windowSplashScreenAnimatedIcon">@drawable/icon_logo</item>

        <item name="windowSplashScreenIconBackgroundColor">@color/primary</item>

        <item name="postSplashScreenTheme">@style/Base.Theme.MealPlanner</item>
    </style>

</resources>