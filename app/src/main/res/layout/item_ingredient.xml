<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.MealPlanner.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="12dp"
    app:shapeAppearance="@style/ShapeAppearance.MealPlanner.LargeComponent"
    app:strokeColor="@color/outline"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp">

        <View
            android:id="@+id/viewIconBackground"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/ingredient_icon_background"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivIngredientIcon"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:contentDescription="@string/ingredient_icon"
            app:layout_constraintBottom_toBottomOf="@id/viewIconBackground"
            app:layout_constraintEnd_toEndOf="@id/viewIconBackground"
            app:layout_constraintStart_toStartOf="@id/viewIconBackground"
            app:layout_constraintTop_toTopOf="@id/viewIconBackground"
            tools:src="@drawable/ic_ingredient"
            tools:tint="@color/warning" />

        <TextView
            android:id="@+id/tvIngredientName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:textAppearance="@style/TextAppearance.MealPlanner.TitleMedium"
            android:textColor="@color/text_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvIngredientAmount"
            app:layout_constraintStart_toEndOf="@id/viewIconBackground"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Butter" />

        <TextView
            android:id="@+id/tvIngredientAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.MealPlanner.TitleSmall"
            android:textColor="@color/text_secondary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="270gr" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>