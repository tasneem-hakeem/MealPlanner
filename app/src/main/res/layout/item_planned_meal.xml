<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mealCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/Widget.MealPlanner.Card.Meal"
    android:layout_marginBottom="12dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Meal Image -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/mealImage"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            app:shapeAppearance="@style/ShapeAppearance.MealPlanner.MediumComponent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/img_placeholder" />

        <!-- Meal Name -->
        <TextView
            android:id="@+id/mealName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:textAppearance="@style/TextAppearance.MealPlanner.TitleMedium"
            android:textColor="@color/text_primary"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintEnd_toStartOf="@id/deleteButton"
            app:layout_constraintStart_toEndOf="@id/mealImage"
            app:layout_constraintTop_toTopOf="@id/mealImage"
            tools:text="Spaghetti Carbonara" />

        <!-- Category Chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/mealCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            style="@style/Widget.MealPlanner.Chip.Info"
            app:chipMinHeight="28dp"
            app:chipIconVisible="false"
            app:layout_constraintStart_toEndOf="@id/mealImage"
            app:layout_constraintTop_toBottomOf="@id/mealName"
            tools:text="Pasta" />

        <!-- Country -->
        <TextView
            android:id="@+id/mealCountry"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:textAppearance="@style/TextAppearance.MealPlanner.Caption"
            android:textColor="@color/text_tertiary"
            android:drawablePadding="4dp"
            android:gravity="center_vertical"
            app:drawableStartCompat="@drawable/ic_ingredient"
            app:drawableTint="@color/text_tertiary"
            app:layout_constraintStart_toEndOf="@id/mealCategory"
            app:layout_constraintTop_toTopOf="@id/mealCategory"
            app:layout_constraintBottom_toBottomOf="@id/mealCategory"
            tools:text="ITALIAN" />

        <!-- Delete Button -->
        <ImageView
            android:id="@+id/deleteButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_ingredient"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/error"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="Delete meal" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>